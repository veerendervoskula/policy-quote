{
  "name": "policy-quote",
  "private": true,
  "description": "PolicyQuote: Full-stack home insurance quoting application",
  "scripts": {
    "start": "concurrently \"npm run start:api\" \"npm run start:web\"",
    "start:web": "npm --prefix packages/frontend start",
    "start:api": "npm --prefix packages/backend start",
    "build": "concurrently npm run build:web && npm run build:api",
    "build:web": "npm --prefix packages/frontend run build",
    "build:api": "npm --prefix packages/backend run build"
  },
  "devDependencies": {
    "concurrently": "^9.2.3"
  }
}
